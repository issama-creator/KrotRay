BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
MINI_APP_URL=https://krot-ray.vercel.app
API_URL=http://localhost:8000
# Запуск фоновых jobs внутри API (рекомендуется 0, если есть отдельный workers процесс)
RUN_BACKGROUND_JOBS_IN_API=0
# Control plane (Flutter): в проде — PostgreSQL. Локально часто sqlite:///./krotray.db
DATABASE_URL=sqlite:///./krotray.db
# DATABASE_URL=postgresql://user:password@localhost:5432/krotray
# ЮKassa (Итерация 5)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Куда вернуть пользователя после оплаты. По умолчанию — в бота (личный кабинет). Можно указать свой URL.
PAYMENT_RETURN_URL=https://t.me/krotraybot

# Xray gRPC (Итерация 6.1): тег inbound для AddUser
XRAY_INBOUND_TAG=vless-in

# Первый сервер (для скрипта scripts/add_first_server.py)
# Xray на отдельном сервере — укажи его IP и gRPC-порт из конфига Xray (API)
# Пример: Xray на 103.137.251.165, бот на krotray.ru — host=103.137.251.165
XRAY_SERVER_NAME=Main
XRAY_SERVER_HOST=103.137.251.165
XRAY_GRPC_PORT=8080
XRAY_MAX_USERS=100

# VLESS-ссылка (6.2): в шаблоне подставь {uuid} — бэкенд подставит UUID пользователя
VLESS_URL_TEMPLATE=vless://{uuid}@103.137.251.165:443?encryption=none&flow=xtls-rprx-vision&security=reality&sni=www.apple.com&fp=chrome&pbk=OgH3-UkoJbWUhmz_bTPmUbRQbAOyRhIgQ841KI4C42w&sid=568d2499&type=tcp#KrotRay

# Edge top cache (Redis)
# EDGE_REDIS_URL=redis://127.0.0.1:6379/0
EDGE_TOP_CACHE_REFRESH_SEC=10
EDGE_TOP_CACHE_TTL_SEC=30
EDGE_TOP_CACHE_KEY=edge:top:candidates:v1